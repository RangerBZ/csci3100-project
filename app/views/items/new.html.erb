<div class="head-title">
  <h1>✨ Marketplace</h1>
  <div class="user-actions">
    <p style="font-size: 1.25rem; font-weight: 600; margin-right:40px"> Hello <%= @user&.name || "Guest" %>! </p>
    <div class="dropdown">
      <% if current_user.present? %>
        <%= link_to "👤 View My Profile", user_path(current_user), class: "dropdown-link" %>
        <%= link_to "🚪 Log Out", logout_path, data: { turbo_method: :delete }, class: "dropdown-link logout" %>
      <% end %>
    </div>
  </div>
</div>

<div class="form-container">
  <div class="form-card">
    <div class="form-header">
      <h1>💡 Post New Item</h1>
      <p>Share your item with the community!</p>
    </div>

    <% if @item.errors.any? %>
      <div style="background: #fed7d7; padding: 12px; border-radius: 8px; margin-bottom: 20px; color: #742a2a;">
        ⚠️ <%= pluralize(@item.errors.count, "error") %> prohibited this item from being posted:
        <ul>
          <% @item.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= render "form", item: @item %>
  </div>
</div>
